---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

import "../styles/global.css";

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en" class="bg-neutral-200">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="description"
      content="The personal website of William Wingate"
    />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/mallard.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body
    class="min-h-screen max-w-2xl my-0 mx-auto p-6 bg-neutral-50 drop-shadow-md"
  >
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
